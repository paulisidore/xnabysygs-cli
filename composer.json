{
    "name": "nabysyphpapi/xnabysygs-cli",
    "description": "CLI globale du framework NAbySyGS — commandes nsy et koro",
    "type": "project",
    "version": "1.3.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Paul Isidore",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "classmap": [
            "src/NAbySyCLI.php"
        ]
    },
    "bin": [
        "bin/nsy",
        "bin/koro"
    ],
    "config": {
        "optimize-autoloader": true
    }
}
